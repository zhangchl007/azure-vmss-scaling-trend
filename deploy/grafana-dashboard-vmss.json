{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Azure Monitor managed Prometheus (or any Prometheus) data source.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "bargauge", "name": "Bar gauge", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Azure VM Scale Set inventory and instance count trends from the Prometheus exporter (azure_vmss_*).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Overview",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "id": 1,
      "title": "VMSS observed",
      "description": "Number of VM Scale Sets discovered in the last successful collection.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "targets": [
        {
          "expr": "max(azure_vmss_exporter_vmss_total{job=\"$job\"})",
          "legendFormat": "VMSS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Total VM instances",
      "description": "Sum of actual VM instance counts across all selected VMSS.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "targets": [
        {
          "expr": "sum(\n  max by (subscription_id, resource_group, vmss_name, location, orchestration_mode) (\n    azure_vmss_instance_count{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", vmss_name=~\"$vmss_name\", location=~\"$location\"}\n  )\n)",
          "legendFormat": "instances",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Total desired capacity",
      "description": "Sum of desired capacity (VMSS.sku.capacity) across selected VMSS.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "targets": [
        {
          "expr": "sum(\n  max by (subscription_id, resource_group, vmss_name, location, orchestration_mode) (\n    azure_vmss_capacity{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", vmss_name=~\"$vmss_name\", location=~\"$location\"}\n  )\n)",
          "legendFormat": "capacity",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Scale gap (capacity - actual)",
      "description": "Count of VMSS where desired capacity differs from the actual observed VM instance count.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "targets": [
        {
          "expr": "count(\n  (\n    max by (subscription_id, resource_group, vmss_name, location, orchestration_mode) (\n      azure_vmss_capacity{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", vmss_name=~\"$vmss_name\", location=~\"$location\"}\n    )\n    - on (subscription_id, resource_group, vmss_name, location, orchestration_mode)\n      max by (subscription_id, resource_group, vmss_name, location, orchestration_mode) (\n        azure_vmss_instance_count{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", vmss_name=~\"$vmss_name\", location=~\"$location\"}\n      )\n  )\n  != 0\n) or vector(0)",
          "legendFormat": "diverging",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Exporter freshness",
      "description": "Seconds since the last successful Azure Resource Graph collection. Should stay below the poll interval (default 300s) plus margin.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "targets": [
        {
          "expr": "time() - max(azure_vmss_exporter_last_success_timestamp_seconds{job=\"$job\"})",
          "legendFormat": "age",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 600},
              {"color": "red", "value": 1800}
            ]
          },
          "unit": "s",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "stat",
      "id": 6,
      "title": "Collection errors (5m rate)",
      "description": "Rate of failed Azure Resource Graph collections in the last 5 minutes.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "targets": [
        {
          "expr": "sum(rate(azure_vmss_exporter_collection_errors_total{job=\"$job\"}[5m]))",
          "legendFormat": "errors/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.0001},
              {"color": "red", "value": 0.01}
            ]
          },
          "unit": "ops",
          "decimals": 4
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "row",
      "id": 101,
      "title": "Trends",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "VMSS instance count trend (per VMSS, non-zero)",
      "description": "TRUE line chart: Y axis = actual VM instance count. Each VMSS is one colored line. Two VMSS with identical instance counts overlap at the same Y position by design (this is the truth — they have the same value). Use the colored legend on the right to identify every VMSS, and refer to the State Timeline panel on the right (or below) for an unambiguous per-VMSS row view. Filter `> 0` hides VMSS that currently have zero instances.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 10, "w": 14, "x": 0, "y": 6},
      "targets": [
        {
          "expr": "max by (subscription_id, resource_group, vmss_name, location, orchestration_mode) (\n  azure_vmss_instance_count{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", vmss_name=~\"$vmss_name\", location=~\"$location\"}\n) > 0",
          "legendFormat": "{{vmss_name}} · {{resource_group}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 3,
            "fillOpacity": 0,
            "showPoints": "always",
            "pointSize": 8,
            "spanNulls": true,
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "axisLabel": "instances",
            "axisSoftMin": 0,
            "scaleDistribution": {"type": "linear"}
          },
          "color": {"mode": "palette-classic"},
          "unit": "short",
          "decimals": 0,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["lastNotNull", "min", "max", "mean"]
        },
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "type": "state-timeline",
      "id": 13,
      "title": "Per-VMSS instance count timeline",
      "description": "One horizontal row per VMSS. Color encodes the instance count at each time bucket. Zero geometric overlap by construction: every VMSS — even those sharing identical counts in the trend chart on the left — gets its own dedicated row, so all VMSS are always visible regardless of their value.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 10, "w": 10, "x": 14, "y": 6},
      "targets": [
        {
          "expr": "max by (subscription_id, resource_group, vmss_name, location, orchestration_mode) (\n  azure_vmss_instance_count{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", vmss_name=~\"$vmss_name\", location=~\"$location\"}\n) > 0",
          "legendFormat": "{{vmss_name}} · {{resource_group}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "transparent", "value": null},
              {"color": "blue", "value": 1},
              {"color": "green", "value": 2},
              {"color": "yellow", "value": 4},
              {"color": "orange", "value": 8},
              {"color": "red", "value": 16}
            ]
          },
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 80
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "left",
        "rowHeight": 0.9,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false
        },
        "tooltip": {"mode": "single", "sort": "none"}
      }
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Total instances by subscription",
      "description": "Aggregate VM instances per Azure subscription.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum by (subscription_id) (\n  max by (subscription_id, resource_group, vmss_name, location, orchestration_mode) (\n    azure_vmss_instance_count{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", vmss_name=~\"$vmss_name\", location=~\"$location\"}\n  )\n)",
          "legendFormat": "{{subscription_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {"mode": "normal", "group": "A"}
          },
          "color": {"mode": "palette-classic"},
          "unit": "short",
          "decimals": 0,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "Total instances by location",
      "description": "Aggregate VM instances per Azure region.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "sum by (location) (\n  max by (subscription_id, resource_group, vmss_name, location, orchestration_mode) (\n    azure_vmss_instance_count{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", vmss_name=~\"$vmss_name\", location=~\"$location\"}\n  )\n)",
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {"mode": "normal", "group": "A"}
          },
          "color": {"mode": "palette-classic"},
          "unit": "short",
          "decimals": 0,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "type": "row",
      "id": 102,
      "title": "Current snapshot",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "bargauge",
      "id": 10,
      "title": "Current instance count by VMSS",
      "description": "Most recent observed VM instance count, sorted descending. Labels include resource group so VMSS with identical names across clusters are not collapsed.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 12, "w": 12, "x": 0, "y": 25},
      "targets": [
        {
          "expr": "max by (subscription_id, resource_group, vmss_name, location, orchestration_mode) (\n  azure_vmss_instance_count{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", vmss_name=~\"$vmss_name\", location=~\"$location\"}\n)",
          "legendFormat": "{{vmss_name}} · {{resource_group}}",
          "refId": "A",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 50},
              {"color": "red", "value": 100}
            ]
          },
          "unit": "short",
          "decimals": 0,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "table",
      "id": 11,
      "title": "VMSS inventory (latest)",
      "description": "Current VMSS view with VM size, desired capacity, actual instances, and drift.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 12, "w": 12, "x": 12, "y": 25},
      "targets": [
        {
          "expr": "max by (subscription_id, resource_group, vmss_name, location, orchestration_mode) (\n  azure_vmss_instance_count{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", vmss_name=~\"$vmss_name\", location=~\"$location\"}\n)\n* on (subscription_id, resource_group, vmss_name, location, orchestration_mode) group_left(vm_size)\nmax by (subscription_id, resource_group, vmss_name, location, orchestration_mode, vm_size) (\n  azure_vmss_info{job=\"$job\"}\n)",
          "legendFormat": "__auto",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "expr": "max by (subscription_id, resource_group, vmss_name, location, orchestration_mode) (\n  azure_vmss_capacity{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", vmss_name=~\"$vmss_name\", location=~\"$location\"}\n)\n* on (subscription_id, resource_group, vmss_name, location, orchestration_mode) group_left(vm_size)\nmax by (subscription_id, resource_group, vmss_name, location, orchestration_mode, vm_size) (\n  azure_vmss_info{job=\"$job\"}\n)",
          "legendFormat": "__auto",
          "refId": "B",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "namespace": true,
              "pod": true,
              "node": true,
              "container": true,
              "endpoint": true
            },
            "indexByName": {
              "subscription_id": 0,
              "resource_group": 1,
              "vmss_name": 2,
              "vm_size": 3,
              "location": 4,
              "orchestration_mode": 5,
              "Value #A": 6,
              "Value #B": 7
            },
            "renameByName": {
              "Value #A": "instances",
              "Value #B": "capacity",
              "subscription_id": "subscription",
              "resource_group": "resource group",
              "vmss_name": "vmss",
              "vm_size": "vm size",
              "location": "region",
              "orchestration_mode": "mode"
            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "drift",
            "mode": "binary",
            "binary": {"left": "capacity", "operator": "-", "right": "instances"},
            "reduce": {"reducer": "sum"},
            "replaceFields": false
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true,
            "cellOptions": {"type": "auto"}
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "instances"},
            "properties": [
              {"id": "custom.cellOptions", "value": {"type": "color-text"}},
              {"id": "color", "value": {"mode": "thresholds"}},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "text", "value": null},
                    {"color": "green", "value": 1}
                  ]
                }
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "drift"},
            "properties": [
              {"id": "custom.cellOptions", "value": {"type": "color-background"}},
              {"id": "color", "value": {"mode": "thresholds"}},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "transparent", "value": null},
                    {"color": "orange", "value": 1},
                    {"color": "red", "value": 5}
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "sortBy": [{"displayName": "instances", "desc": true}]
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "row",
      "id": 103,
      "title": "Capacity vs actual",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 37},
      "collapsed": true,
      "panels": [
        {
          "type": "timeseries",
          "id": 12,
          "title": "Capacity vs actual (selected VMSS)",
          "description": "Compare desired VMSS capacity to actual observed VM count. Use the vmss_name variable to focus on specific scale sets.",
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "gridPos": {"h": 10, "w": 24, "x": 0, "y": 38},
          "targets": [
            {
              "expr": "max by (subscription_id, resource_group, vmss_name, location, orchestration_mode) (\n  azure_vmss_capacity{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", vmss_name=~\"$vmss_name\", location=~\"$location\"}\n)",
              "legendFormat": "{{vmss_name}} · {{resource_group}} capacity",
              "refId": "A"
            },
            {
              "expr": "max by (subscription_id, resource_group, vmss_name, location, orchestration_mode) (\n  azure_vmss_instance_count{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", vmss_name=~\"$vmss_name\", location=~\"$location\"}\n)",
              "legendFormat": "{{vmss_name}} · {{resource_group}} actual",
              "refId": "B"
            }
          ],
