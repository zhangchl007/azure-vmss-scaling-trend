{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Azure Monitor managed Prometheus (or any Prometheus) data source.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "bargauge", "name": "Bar gauge", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""},
    {"type": "panel", "id": "heatmap", "name": "Heatmap", "version": ""}
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Azure Managed Lustre OST bytes available trends from the Prometheus exporter (azure_managed_lustre_*).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Overview",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Lustre filesystems observed",
      "description": "Number of Azure Managed Lustre filesystems discovered in the latest collection.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 3, "x": 0, "y": 1},
      "targets": [
        {
          "expr": "max(azure_managed_lustre_filesystem_total{job=\"$job\"})",
          "legendFormat": "filesystems",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "stat",
      "id": 2,
      "title": "OST series observed",
      "description": "Count of selected OSTBytesAvailable time series currently exported.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 3, "x": 3, "y": 1},
      "targets": [
        {
          "expr": "count(max by (subscription_id, resource_group, filesystem_name, location, ostnum) (\n  azure_managed_lustre_ost_bytes_available{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", filesystem_name=~\"$filesystem_name\", location=~\"$location\", ostnum=~\"$ostnum\"}\n)) or vector(0)",
          "legendFormat": "OSTs",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Total bytes available",
      "description": "Sum of latest OST bytes available across selected Lustre filesystems and OSTs.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 3, "x": 6, "y": 1},
      "targets": [
        {
          "expr": "sum(\n  max by (subscription_id, resource_group, filesystem_name, location, ostnum) (\n    azure_managed_lustre_ost_bytes_available{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", filesystem_name=~\"$filesystem_name\", location=~\"$location\", ostnum=~\"$ostnum\"}\n  )\n)",
          "legendFormat": "bytes available",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "bytes",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Minimum OST available %",
      "description": "Smallest latest available-capacity percentage across selected OSTs; this is the primary normalized capacity-pressure signal.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 3, "x": 9, "y": 1},
      "targets": [
        {
          "expr": "min(\n  max by (subscription_id, resource_group, filesystem_name, location, ostnum) (\n    azure_managed_lustre_ost_bytes_available_percent{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", filesystem_name=~\"$filesystem_name\", location=~\"$location\", ostnum=~\"$ostnum\"}\n  )\n)",
          "legendFormat": "minimum %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 5},
              {"color": "green", "value": 10}
            ]
          },
          "unit": "percent",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Lustre collector freshness",
      "description": "Seconds since the last successful Managed Lustre collection. Should stay below the 60s Lustre poll interval plus margin.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 3, "x": 12, "y": 1},
      "targets": [
        {
          "expr": "time() - max(azure_managed_lustre_last_success_timestamp_seconds{job=\"$job\"})",
          "legendFormat": "age",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 180},
              {"color": "red", "value": 300}
            ]
          },
          "unit": "s",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "stat",
      "id": 14,
      "title": "Max OST sample age",
      "description": "Maximum age in seconds of Azure Monitor OSTBytesAvailable samples across selected OSTs. This catches Azure Monitor ingestion lag even when the exporter is running.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 3, "x": 15, "y": 1},
      "targets": [
        {
          "expr": "max(\n  time() - azure_managed_lustre_ost_sample_timestamp_seconds{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", filesystem_name=~\"$filesystem_name\", location=~\"$location\", ostnum=~\"$ostnum\"}\n)",
          "legendFormat": "sample age",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 180},
              {"color": "red", "value": 300}
            ]
          },
          "unit": "s",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "stat",
      "id": 6,
      "title": "Lustre errors (5m rate)",
      "description": "Rate of failed Azure Managed Lustre collection calls over the last 5 minutes.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 3, "x": 18, "y": 1},
      "targets": [
        {
          "expr": "sum(rate(azure_managed_lustre_collection_errors_total{job=\"$job\"}[5m]))",
          "legendFormat": "errors/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.0001},
              {"color": "red", "value": 0.01}
            ]
          },
          "unit": "ops",
          "decimals": 4
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "stat",
      "id": 15,
      "title": "Lustre collection duration",
      "description": "Duration of the most recent Managed Lustre collection attempt. If this approaches the poll interval, reduce cluster fan-out or increase workers carefully.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 3, "x": 21, "y": 1},
      "targets": [
        {
          "expr": "max(azure_managed_lustre_collection_duration_seconds{job=\"$job\"})",
          "legendFormat": "duration",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 30},
              {"color": "red", "value": 60}
            ]
          },
          "unit": "s",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "row",
      "id": 101,
      "title": "Trends",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "Lowest OST available % trend (bottom $top_n by $rank_by)",
      "description": "One line per selected Lustre OST, focused on the bottom $top_n OSTs with the lowest available percentage. This is the alert-first view.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 10, "w": 14, "x": 0, "y": 6},
      "targets": [
        {
          "expr": "bottomk($top_n,\n  $rank_by by (subscription_id, resource_group, filesystem_name, location, ostnum) (\n    azure_managed_lustre_ost_bytes_available_percent{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", filesystem_name=~\"$filesystem_name\", location=~\"$location\", ostnum=~\"$ostnum\"}\n  )\n)",
          "legendFormat": "{{filesystem_name}} · OST {{ostnum}} · {{resource_group}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "pointSize": 5,
            "spanNulls": true,
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "axisLabel": "available %",
            "axisSoftMin": 0,
            "scaleDistribution": {"type": "linear"}
          },
          "color": {"mode": "palette-classic"},
          "unit": "percent",
          "decimals": 2,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["lastNotNull", "min", "max", "mean"]
        },
        "tooltip": {"mode": "multi", "sort": "asc"}
      }
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "Total bytes available by filesystem",
      "description": "Sum of OSTBytesAvailable by Azure Managed Lustre filesystem.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 10, "w": 10, "x": 14, "y": 6},
      "targets": [
        {
          "expr": "topk($top_n,\n  sum by (subscription_id, resource_group, filesystem_name, location) (\n    max by (subscription_id, resource_group, filesystem_name, location, ostnum) (\n      azure_managed_lustre_ost_bytes_available{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", filesystem_name=~\"$filesystem_name\", location=~\"$location\", ostnum=~\"$ostnum\"}\n    )\n  )\n)",
          "legendFormat": "{{filesystem_name}} · {{resource_group}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {"mode": "none", "group": "A"}
          },
          "color": {"mode": "palette-classic"},
          "unit": "bytes",
          "decimals": 2,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "type": "row",
      "id": 102,
      "title": "Aggregations & Distribution",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 16},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "Total bytes available by resource group",
      "description": "Stacked total bytes available grouped by Azure resource group.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 17},
      "targets": [
        {
          "expr": "topk($top_n,\n  sum by (resource_group) (\n    max by (subscription_id, resource_group, filesystem_name, location, ostnum) (\n      azure_managed_lustre_ost_bytes_available{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", filesystem_name=~\"$filesystem_name\", location=~\"$location\", ostnum=~\"$ostnum\"}\n    )\n  )\n)",
          "legendFormat": "{{resource_group}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 40,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {"mode": "normal", "group": "A"}
          },
          "color": {"mode": "palette-classic"},
          "unit": "bytes",
          "decimals": 2,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "Total bytes available by subscription",
      "description": "Aggregate bytes available per Azure subscription.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 17},
      "targets": [
        {
          "expr": "sum by (subscription_id) (\n  max by (subscription_id, resource_group, filesystem_name, location, ostnum) (\n    azure_managed_lustre_ost_bytes_available{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", filesystem_name=~\"$filesystem_name\", location=~\"$location\", ostnum=~\"$ostnum\"}\n  )\n)",
          "legendFormat": "{{subscription_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 30,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {"mode": "normal", "group": "A"}
          },
          "color": {"mode": "palette-classic"},
          "unit": "bytes",
          "decimals": 2,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "Total bytes available by location",
      "description": "Aggregate bytes available per Azure region.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 17},
      "targets": [
        {
          "expr": "sum by (location) (\n  max by (subscription_id, resource_group, filesystem_name, location, ostnum) (\n    azure_managed_lustre_ost_bytes_available{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", filesystem_name=~\"$filesystem_name\", location=~\"$location\", ostnum=~\"$ostnum\"}\n  )\n)",
          "legendFormat": "{{location}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 30,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {"mode": "normal", "group": "A"}
          },
          "color": {"mode": "palette-classic"},
          "unit": "bytes",
          "decimals": 2,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "type": "row",
      "id": 103,
      "title": "Current snapshot",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 25},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "bargauge",
      "id": 12,
      "title": "Lowest current available % by OST",
      "description": "Bottom $top_n current available-capacity percentage values. Use filesystem and OST variables to drill down.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 12, "w": 12, "x": 0, "y": 26},
      "targets": [
        {
          "expr": "bottomk($top_n,\n  max by (subscription_id, resource_group, filesystem_name, location, ostnum) (\n    azure_managed_lustre_ost_bytes_available_percent{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", filesystem_name=~\"$filesystem_name\", location=~\"$location\", ostnum=~\"$ostnum\"}\n  )\n)",
          "legendFormat": "{{filesystem_name}} · OST {{ostnum}} · {{resource_group}}",
          "refId": "A",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 5},
              {"color": "green", "value": 10}
            ]
          },
          "unit": "percent",
          "decimals": 2,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "pluginVersion": "10.4.0"
    },
    {
      "type": "table",
      "id": 13,
      "title": "Managed Lustre OST inventory (latest)",
      "description": "Current Azure Managed Lustre OST capacity by subscription, resource group, filesystem, region, and OST number.",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 12, "w": 12, "x": 12, "y": 26},
      "targets": [
        {
          "expr": "max by (subscription_id, resource_group, filesystem_name, location, ostnum) (\n  azure_managed_lustre_ost_bytes_available{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", filesystem_name=~\"$filesystem_name\", location=~\"$location\", ostnum=~\"$ostnum\"}\n)",
          "legendFormat": "__auto",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "expr": "max by (subscription_id, resource_group, filesystem_name, location, ostnum) (\n  azure_managed_lustre_ost_bytes_used{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", filesystem_name=~\"$filesystem_name\", location=~\"$location\", ostnum=~\"$ostnum\"}\n)",
          "legendFormat": "__auto",
          "refId": "B",
          "format": "table",
          "instant": true
        },
        {
          "expr": "max by (subscription_id, resource_group, filesystem_name, location, ostnum) (\n  azure_managed_lustre_ost_bytes_total{job=\"$job\", subscription_id=~\"$subscription_id\", resource_group=~\"$resource_group\", filesystem_name=~\"$filesystem_name\", location=~\"$location\", ostnum=~\"$ostnum\"}\n)",
          "legendFormat": "__auto",
          "refId": "C",
          "format": "table",
          "instant": true
