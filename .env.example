# Comma-separated subscription IDs to query.
AZURE_SUBSCRIPTION_IDS=00000000-0000-0000-0000-000000000000

# Optional for local development when DefaultAzureCredential should target a specific tenant.
# AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# Poll Azure Resource Graph every 5 minutes by default.
POLL_INTERVAL_SECONDS=300

# Prometheus HTTP endpoint settings.
HOST=0.0.0.0
PORT=8000

# Logging.
LOG_LEVEL=INFO

# Query behavior.
ARG_PAGE_SIZE=1000
ARG_MAX_RETRIES=3
ARG_RETRY_BASE_DELAY_SECONDS=1.0
