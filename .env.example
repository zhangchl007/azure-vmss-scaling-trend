# Comma-separated subscription IDs to query.
AZURE_SUBSCRIPTION_IDS=00000000-0000-0000-0000-000000000000

# Optional for local development when DefaultAzureCredential should target a specific tenant.
# AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# Auth mode for local/CI runs. Kubernetes deployments should set this in deploy/kubernetes.yaml.
# Supported values: auto, workload_identity, service_principal.
VMSS_METRICS_AUTH_MODE=auto

# Optional Service Principal auth for local/CI/non-AKS runs.
# When these three values are set, Service Principal auth takes precedence over
# AKS Workload Identity, even if AZURE_FEDERATED_TOKEN_FILE is also present.
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
# AZURE_CLIENT_SECRET=replace-with-secret-value

# Poll Azure Resource Graph every 5 minutes by default.
POLL_INTERVAL_SECONDS=300

# Prometheus HTTP endpoint settings.
HOST=0.0.0.0
PORT=8000

# Logging.
LOG_LEVEL=INFO

# Query behavior.
ARG_PAGE_SIZE=1000
ARG_MAX_RETRIES=3
ARG_RETRY_BASE_DELAY_SECONDS=1.0

# Azure Managed Lustre metrics. Discovers all Microsoft.StorageCache/amlFilesystems
# resources in AZURE_SUBSCRIPTION_IDS and queries Azure Monitor for OSTBytesAvailable.
ENABLE_MANAGED_LUSTRE_METRICS=true
LUSTRE_POLL_INTERVAL_SECONDS=60
LUSTRE_METRICS_LOOKBACK_MINUTES=15
LUSTRE_METRICS_INTERVAL=PT1M
LUSTRE_METRICS_MAX_WORKERS=4
